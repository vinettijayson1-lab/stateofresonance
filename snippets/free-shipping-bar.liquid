{% liquid
  assign free_shipping_threshold = settings.free_shipping_threshold | default: 8000 | times: 1
  assign cart_total = cart.total_price
  assign amount_left = free_shipping_threshold | minus: cart_total

  if cart_total >= free_shipping_threshold
    assign percentage = 100
    assign message = 'You have got <strong>Free Shipping!</strong>'
  else
    assign percentage = cart_total | times: 1.0 | divided_by: free_shipping_threshold | times: 100
    assign amount_left_money = amount_left | money
    assign message = 'You are only <strong>' | append: amount_left_money | append: '</strong> away from Free Shipping!'
  endif
%}

<div class="free-shipping-bar">
  <div class="free-shipping-bar__message">{{ message }}</div>
  <div class="free-shipping-bar__progress-container">
    <div class="free-shipping-bar__progress-fill" style="width: {{ percentage }}%;"></div>
  </div>
</div>

<style>
  .free-shipping-bar {
    width: 100%;
    margin-bottom: 16px;
    text-align: center;
    padding: 0 16px;
  }
  .free-shipping-bar__message {
    font-size: 0.9em;
    margin-bottom: 8px;
    color: var(--color-foreground);
  }
  .free-shipping-bar__progress-container {
    width: 100%;
    height: 8px;
    background-color: var(--color-border);
    border-radius: 4px;
    overflow: hidden;
  }
  .free-shipping-bar__progress-fill {
    height: 100%;
    background-color: #22c55e; /* Green color suitable for positive reinforcement */
    transition: width 0.3s ease;
  }
</style>
