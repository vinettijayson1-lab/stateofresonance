{
  "buildCommand": "npm run build",
  "installCommand": "npm install --legacy-peer-deps",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "prisma/prod_v5300.sqlite"
    }
  },
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/sanctuary.html", "destination": "/sanctuary", "permanent": true },
    { "source": "/attire.html", "destination": "/attire", "permanent": true },
    { "source": "/alchemy.html", "destination": "/alchemy", "permanent": true },
    { "source": "/blog.html", "destination": "/transmissions", "permanent": true },
    { "source": "/void.html", "destination": "/void", "permanent": true },
    { "source": "/product.html", "destination": "/sanctuary", "permanent": true },
    { "source": "/collection.html", "destination": "/sanctuary", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/marketing/influencer_shipping", "destination": "/api/marketing/influencer_fulfillment" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(assets|images|fonts)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/audio/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Accept-Ranges", "value": "bytes" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ]
}
