{%- style -%}
  .brand-manifesto--{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background: {{ section.settings.background_gradient }};
    position: relative;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .brand-manifesto--{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .manifesto-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 2;
  }

  .manifesto-title {
    font-family: var(--font-heading-family);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 300;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-foreground-heading);
    margin-bottom: 2rem;
    line-height: 1.1;
  }

  .manifesto-text {
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    line-height: 1.8;
    color: var(--color-foreground);
    opacity: 0.9;
    font-weight: 300;
    letter-spacing: 0.05em;
  }

  .manifesto-text strong {
    color: var(--color-foreground-heading);
    font-weight: 400;
  }

  .manifesto-sigil {
    width: 60px;
    height: 60px;
    margin: 0 auto 3rem;
    opacity: 0.5;
    filter: drop-shadow(0 0 10px rgba(255,255,255,0.2));
  }
{%- endstyle -%}

<div class="brand-manifesto--{{ section.id }} section">
  <div class="manifesto-content cro-fade-in">
    <div class="manifesto-sigil">
      <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="50" cy="50" r="48" stroke="currentColor" stroke-width="0.5"/>
        <path d="M50 2L50 98" stroke="currentColor" stroke-width="0.5"/>
        <path d="M2 50L98 50" stroke="currentColor" stroke-width="0.5"/>
        <circle cx="50" cy="50" r="20" stroke="currentColor" stroke-width="0.5"/>
      </svg>
    </div>
    
    <h2 class="manifesto-title">{{ section.settings.heading }}</h2>
    <div class="manifesto-text">
      {{ section.settings.text }}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Brand Manifesto",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "The Alignment",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "text",
      "default": "<p>We don't just make clothing; we engineer <strong>Resonance</strong>. Through our <strong>Protocol 426-HZ</strong> gear and embedded audio frequencies, we provide the physical and digital tools to silence the static and find your ground.</p>",
      "label": "Text"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background Gradient",
      "default": "radial-gradient(circle at center, #1a1a1a 0%, #0b0e14 100%)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Brand Manifesto"
    }
  ]
}
{% endschema %}
