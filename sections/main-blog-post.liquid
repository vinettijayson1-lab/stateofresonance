

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section color-{{ section.settings.color_scheme }}">
  <div
    class="
      spacing-style
      layout-panel-flex
      layout-panel-flex--column
      section-content-wrapper
      mobile-column
    "
    style="
      {% render 'layout-panel-style', settings: section.settings %}
      {% render 'spacing-style', settings: section.settings %}
    "
  >
    <header>
      {%- content_for 'block', id: 'blog-post-title', type: 'text' %}
    </header>

    {%- if article.image -%}
      {%- content_for 'block', id: 'blog-post-image', type: '_blog-post-featured-image' %}
    {%- endif -%}
    {%- content_for 'block', id: 'blog-post-content', type: '_blog-post-content' %}

    {% comment %} E-E-A-T: Author Bio Section {% endcomment %}
    <div class="article-author-bio">
      <div class="article-author-bio__avatar">
        {% assign author_initials = article.author | slice: 0, 1 | upcase %}
        <span>{{ author_initials }}</span>
      </div>
      <div class="article-author-bio__info">
        <h3 class="h5">Written by {{ article.author }}</h3>
        <p>Curator of Resonance, exploring intersections of consciousness, design, and culture.</p>
      </div>
    </div>

    {% comment %} Cross-sell Funnel: Topic-matched related products {% endcomment %}
    {% if article.tags.size > 0 %}
      <div class="article-related-products">
        <h2 class="h3">Explore The Resonance</h2>
        <div class="article-related-products__grid">
          {% assign matched_count = 0 %}
          {% for product in collections.all.products limit: 250 %}
            {% assign match = false %}
            {% for tag in article.tags %}
              {% if product.tags contains tag %}
                {% assign match = true %}
              {% endif %}
            {% endfor %}
            
            {% if match %}
              <div class="article-related-products__item">
                {% render 'inline-product-card', product: product %}
              </div>
              {% assign matched_count = matched_count | plus: 1 %}
            {% endif %}
            
            {% if matched_count >= 3 %}{% break %}{% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}

    {% comment %} CRO - Inline Blog Lead Capture {% endcomment %}
    <div class="article-lead-capture" style="margin: 4rem auto 0; max-width: var(--normal-content-width); padding: 3rem; background: rgb(var(--color-foreground-rgb) / 0.03); border-radius: 12px; text-align: center;">
      <h2 class="h3" style="margin-top: 0;">Stay in the Loop</h2>
      <p style="margin-bottom: 2rem; color: rgb(var(--color-foreground-rgb) / 0.8);">Get the latest insights and exclusive offers delivered straight to your inbox.</p>
      {% form 'customer', class: 'article-newsletter-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter, blog">
        {% if form.posted_successfully? %}
          <div style="background-color: rgba(var(--color-success-rgb, 40, 167, 69), 0.1); color: rgb(var(--color-success-rgb, 40, 167, 69)); padding: 15px; border-radius: 4px;">
            <p>Thanks for subscribing!</p>
          </div>
        {% else %}
          <div style="display: flex; gap: 10px; max-width: 400px; margin: 0 auto;">
            <input type="email" name="contact[email]" placeholder="Your email address" required style="flex-grow: 1; padding: 12px 15px; border: 1px solid var(--color-border); border-radius: 4px; background-color: var(--color-input-background); color: var(--color-input-text);">
            <button type="submit" class="button button--primary" style="white-space: nowrap;">Subscribe</button>
          </div>
        {% endif %}
      {% endform %}
    </div>

    {% comment %} Dynamic area for @app blocks only, at the bottom {% endcomment %}
    {% content_for 'blocks' %}

    {% if blog.comments_enabled? %}
      <div class="blog-post-comments-container">
        <h2 class="h3">{{- 'blogs.article.comments_heading' | t: count: article.comments_count -}}</h2>

        <div class="blog-post-comments">
          {% paginate article.comments by 10 %}
            {% for comment in article.comments %}
              <div class="blog-post-comment">
                {{ comment.content }}
                <div class="blog-post-comment__author">
                  <span class="blog-post-comment__author-name">{{- comment.author -}}</span>
                  <span>{{- 'blogs.article.comment_author_separator' | t -}}</span>
                  <span class="blog-post-comment__date">
                    {{- comment.created_at | time_tag: format: 'date' -}}
                  </span>
                </div>
              </div>
            {% endfor %}

            <div class="blog-post-comments-pagination">
              {{- paginate | default_pagination -}}
            </div>
          {% endpaginate %}
        </div>

        {% render 'blog-comment-form', article: article, section_id: section.id %}
      </div>
    {% endif %}
  </div>
</div>

<script type="application/ld+json">
{
  "@context": "http://schema.org",
  "@type": "BlogPosting",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ shop.url }}{{ article.url }}"
  },
  "headline": {{ article.title | json }},
  {% if article.image %}
  "image": [
    "{{ article.image | image_url: width: 1200 }}"
  ],
  {% endif %}
  "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' }}",
  "dateModified": "{{ article.updated_at | default: article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' }}",
  "author": {
    "@type": "Person",
    "name": "{{ article.author }}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "{{ shop.name }}",
    "logo": {
      "@type": "ImageObject",
      {% if settings.logo %}
      "url": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }}
      {% else %}
      "url": "https://cdn.shopify.com/s/images/admin/no-image-large.gif"
      {% endif %}
    }
  },
  "articleBody": {{ article.content | strip_html | json }},
  "wordCount": "{{ article.content | strip_html | split: ' ' | size }}"
}
</script>

{% stylesheet %}
  .article-author-bio {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin: 3rem auto 0;
    max-width: var(--normal-content-width);
    padding: 2rem;
    background: rgb(var(--color-foreground-rgb) / 0.02);
    border-radius: 8px;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.05);
  }
  .article-author-bio__avatar {
    flex: 0 0 64px;
    height: 64px;
    background: var(--color-foreground);
    color: var(--color-background);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-family: var(--font-heading--family);
  }
  .article-author-bio__info h3 {
    margin: 0 0 0.5rem 0;
  }
  .article-author-bio__info p {
    margin: 0;
    font-size: 0.95rem;
    color: rgb(var(--color-foreground-rgb) / 0.8);
  }
  .blog-post-comments-container {
    width: 100%;
    max-width: var(--normal-content-width);
    margin: 4rem auto 0;
    padding: 3rem;
    background: rgba(11, 14, 20, 0.6); /* Thoth Midnight with transparency */
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(198, 156, 109, 0.2); /* Faded Gold border */
    border-radius: 12px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5); /* Deep shadow */
  }
  
  .blog-post-comments-container h2 {
    color: var(--color-thoth-gold, #C69C6D);
    text-align: center;
    letter-spacing: 2px;
    margin-bottom: 2rem;
  }

  .blog-post-comments {
    display: flex;
    flex-direction: column;
    gap: var(--gap-3xl);
    margin-bottom: 3rem;
  }
  
  .blog-post-comment {
    background: rgba(20, 54, 33, 0.2); /* Very subtle Emerald tint */
    padding: 2rem;
    border-radius: 8px;
    border-left: 2px solid var(--color-thoth-purple, #8A2BE2);
  }

  .blog-post-comment__author {
    display: flex;
    align-items: center;
    gap: var(--gap-2xs);
    margin-top: var(--margin-md);
    font-size: var(--font-size--body-sm);
    color: var(--color-thoth-gold, #C69C6D);
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .blog-post-comments-pagination {
    display: flex;
    justify-content: center;
    gap: var(--gap-2xs);
  }

  .blog-post-comments-pagination,
  .blog-post-comments-pagination a {
    color: var(--color-thoth-gold, #C69C6D);
  }

  .blog-post-comments-pagination .current {
    color: var(--color-thoth-purple, #8A2BE2);
  }

  .blog-post-comments-pagination .current,
  .blog-post-comments-pagination a {
    display: block;
    padding: var(--padding-2xs) var(--padding-xs);
  }

  .blog-post-comments-pagination .current,
  .blog-post-comments-pagination a:hover {
    border-bottom: 1px solid var(--color-thoth-purple, #8A2BE2);
  }

  /* Related Products Funnel */
  .article-related-products {
    width: 100%;
    margin: 4rem auto 0;
    max-width: var(--normal-content-width);
    border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
    padding-top: 3rem;
  }
  .article-related-products__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .article-related-products__item .inline-product-card {
    margin: 0;
    max-width: 100%;
    height: 100%;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.blog_post",
  "blocks": [
    {
      "type": "@theme"
    },
    {
      "type": "@app"
    }
  ],
  "class": "section-wrapper",
  "settings": [
    {
      "type": "select",
      "id": "content_direction",
      "label": "t:settings.direction",
      "options": [
        {
          "value": "column",
          "label": "t:options.vertical"
        }
      ],
      "default": "column",
      "visible_if": "{{ section.settings.gap < 0 }}"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": []
}
{% endschema %}
