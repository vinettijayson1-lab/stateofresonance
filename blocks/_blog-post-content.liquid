

<div class="blog-post-content rte">
    {% assign article_paragraphs = article.content | split: '</p>' %}
    {% assign half_index = article_paragraphs.size | divided_by: 2 %}
    {% for p in article_paragraphs %}
      
      {% if p contains '[product:' %}
        {% assign p_parts = p | split: '[product:' %}
        {% assign before_product = p_parts[0] %}
        {% assign after_product_part = p_parts[1] | split: ']' %}
        {% assign product_handle = after_product_part[0] | strip_html | strip %}
        {% assign after_product = after_product_part[1] %}
        
        {{ before_product }}
        {% if product_handle != blank %}
          {% assign inline_prod = all_products[product_handle] %}
          {% if inline_prod != blank %}
            <div class="inline-product-injection">
              {% render 'inline-product-card', product: inline_prod %}
            </div>
          {% endif %}
        {% endif %}
        {% # theme-check-disable UnclosedHTMLElement %}
        {{ after_product }}{% if p != blank %}</p>{% endif %}
        {% # theme-check-enable UnclosedHTMLElement %}

      {% else %}
        {% # theme-check-disable UnclosedHTMLElement %}
        {{ p }}{% if p != blank %}</p>{% endif %}
        {% # theme-check-enable UnclosedHTMLElement %}
      {% endif %}

      {% if forloop.index == half_index and half_index > 1 %}
        <div class="inline-newsletter-capture">
          <div class="inline-newsletter-capture__inner">
            <h3 class="h4">Join the Collective</h3>
            <p>Subscribe for early access drops, mind-expanding content, and exclusive streetwear concepts.</p>
            {% form 'customer', class: 'email-signup__form' %}
              <input type="hidden" name="contact[tags]" value="newsletter, Blog_Subscriber">
              <div class="inline-newsletter-capture__input-group">
                <input type="email" name="contact[email]" required placeholder="Email address" class="inline-newsletter-capture__input" autocorrect="off" autocapitalize="off">
                <button type="submit" class="button inline-newsletter-capture__btn">Subscribe</button>
              </div>
              {%- if form.posted_successfully? -%}
                <p class="inline-newsletter-capture__success" tabindex="-1">Access Granted. Welcome to the Resonance.</p>
              {%- endif -%}
            {% endform %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
</div>

{% stylesheet %}
  .blog-post-content {
    max-width: 800px; /* Constrain for readability */
    margin: 0 auto;
    font-size: 1.125rem; /* Larger base font for streetwear aesthetic */
    line-height: 1.8;
    color: rgb(var(--color-foreground-rgb) / 0.9);
  }
  .blog-post-content p {
    margin-bottom: 1.5em;
  }
  .blog-post-content h2, 
  .blog-post-content h3 {
    margin-top: 2em;
    margin-bottom: 1em;
    font-family: var(--font-heading--family);
  }
  .inline-product-injection {
    margin: 2rem 0;
  }

  /* Inline Newsletter Styles */
  .inline-newsletter-capture {
    margin: 3rem 0;
    padding: 2.5rem;
    background: rgb(var(--color-foreground-rgb) / 0.03);
    border-left: 4px solid var(--color-foreground);
    border-radius: 0 8px 8px 0;
  }
  .inline-newsletter-capture__inner h3 {
    margin-top: 0;
    margin-bottom: 0.5rem;
  }
  .inline-newsletter-capture__inner p {
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
  }
  .inline-newsletter-capture__input-group {
    display: flex;
    gap: 0.5rem;
  }
  .inline-newsletter-capture__input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.2);
    border-radius: 4px;
    background: var(--color-background);
    color: var(--color-foreground);
  }
  .inline-newsletter-capture__btn {
    min-height: 44px;
    padding: 0 1.5rem;
  }
  .inline-newsletter-capture__success {
    margin-top: 1rem;
    color: green;
    font-weight: bold;
    font-size: 0.9rem;
  }

  @media screen and (max-width: 600px) {
    .inline-newsletter-capture__input-group {
      flex-direction: column;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.content",
  "settings": [],
  "presets": [
    {
      "name": "t:names.content"
    }
  ]
}
{% endschema %}
